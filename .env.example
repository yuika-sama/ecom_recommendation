# ============================================================
# SentimentIQ — Environment Variables
# Sao chép file này thành .env và điền giá trị thực
# ============================================================

# --- Gemini AI (Google Generative AI) ---
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Gemini Model ---
# Các model có thể dùng: gemini-1.5-flash (nhanh, miễn phí), gemini-1.5-pro (mạnh hơn)
GEMINI_MODEL=gemini-1.5-flash

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Chatbot Config ---
# Ngưỡng similarity để gọi recommend thay vì trả lời chung
CHATBOT_RECOMMEND_THRESHOLD=0.6
